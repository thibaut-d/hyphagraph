########################################
# Global
########################################

ENV=development
PROJECT_NAME=hyphagraph-dev
LOG_LEVEL=info


########################################
# PostgreSQL
########################################

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=hyphagraph_dev
POSTGRES_USER=hyphagraph_dev
POSTGRES_PASSWORD=change-me-dev-password

# SQLAlchemy / asyncpg (backend only)
DATABASE_URL=postgresql+asyncpg://hyphagraph_dev:change-me-dev-password@db:5432/hyphagraph_dev?ssl=disable


########################################
# Backend (FastAPI)
########################################

API_HOST=0.0.0.0
API_PORT=8000

# Security
SECRET_KEY=change-me-dev-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT Configuration
JWT_SECRET_KEY=change-me-dev-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-dev-admin-password

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# Email Configuration
EMAIL_ENABLED=false
EMAIL_FROM=noreply@dev.mydomain.com
EMAIL_FROM_NAME=HyphaGraph Dev

# Frontend URL (for links generated by backend)
FRONTEND_URL=https://dev.mydomain.com

# Email Verification
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24


########################################
# Frontend (React)
########################################

VITE_API_URL=/api
REACT_APP_API_BASE_URL=/api


########################################
# LLM Providers (optional)
########################################

OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=


########################################
# Inference / Computation
########################################

INFERENCE_CACHE_ENABLED=true
INFERENCE_MAX_RELATIONS=1000


########################################
# Development flags
########################################

SQL_DEBUG=false
STRICT_VALIDATION=true
